{
  "name": "argocd-mcp",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter argocd-mcp-server run dev",
    "test": "pnpm --filter argocd-mcp-server run test",
    "test:coverage": "pnpm --filter argocd-mcp-server run test:coverage",
    "lint": "pnpm --filter argocd-mcp-server run lint",
    "typecheck": "pnpm -r run typecheck",
    "format": "pnpm --filter argocd-mcp-server run format",
    "ci": "pnpm --filter argocd-mcp-server run ci",
    "package": "pnpm --filter argocd-mcp-vscode-extension run package",
    "generate-logo": "tsx scripts/generate-logo.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "sharp": "^0.33.5"
  },
  "engines": {
    "node": ">=18"
  }
}
